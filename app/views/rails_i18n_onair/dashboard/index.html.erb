<div class="dashboard-header mb-4">
  <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
  <p class="text-muted">Welcome back, <strong><%= @translator.username %></strong>!</p>

  <div class="card shadow-sm">
    <div class="card-header bg-info text-white">
      <h5 class="mb-0"><i class="bi bi-lightning-charge"></i> Quick Actions</h5>
    </div>
    <div class="card-body">
      <div class="d-grid gap-2 d-md-flex">
        <% if storage_mode_is_database? %>
          <%= link_to translations_path, class: "btn btn-primary" do %>
            <i class="bi bi-list-ul me-2"></i> View All Translations
          <% end %>
          <%= link_to new_translation_path, class: "btn btn-success" do %>
            <i class="bi bi-plus-circle me-2"></i> Add New Translation
          <% end %>
        <% elsif storage_mode_is_file? %>
          <%= link_to locale_files_path, class: "btn btn-primary" do %>
            <i class="bi bi-folder-open me-2"></i> Browse Files
          <% end %>
        <% end %>
        <%= link_to new_sync_locale_path, class: "btn btn-warning" do %>
          <i class="bi bi-arrow-left-right me-2"></i> Sync Locales
        <% end %>
        <%= link_to download_all_path, class: "btn btn-secondary" do %>
          <i class="bi bi-download me-2"></i> Download All Translations
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if storage_mode_is_database? %>
  <%= render "database_mode", statistics: @statistics %>
<% elsif storage_mode_is_file? %>
  <%= render "file_mode", statistics: @statistics %>
<% end %>
