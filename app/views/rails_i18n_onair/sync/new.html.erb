<div class="dashboard-header mb-4">
  <h1><i class="bi bi-arrow-left-right"></i> Sync Locales</h1>
  <p class="text-muted">Compare two locales and copy missing keys from source to destination.</p>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-sliders"></i> Select Locales</h5>
      </div>
      <div class="card-body">
        <% if @locales.count < 2 %>
          <div class="alert alert-warning mb-0">
            <i class="bi bi-exclamation-triangle me-2"></i>
            You need at least 2 locales to use the sync feature.
          </div>
        <% else %>
          <%= form_tag preview_sync_locales_path, method: :post do %>
            <div class="row mb-4">
              <div class="col-md-5">
                <label for="source" class="form-label fw-bold">
                  <i class="bi bi-box-arrow-right me-1"></i> Source Locale
                </label>
                <select name="source" id="source" class="form-select form-select-lg">
                  <option value="">-- Select source --</option>
                  <% @locales.each do |locale| %>
                    <option value="<%= locale %>"><%= locale.upcase %></option>
                  <% end %>
                </select>
                <small class="form-text text-muted">The locale with the complete keys.</small>
              </div>

              <div class="col-md-2 d-flex align-items-center justify-content-center">
                <i class="bi bi-arrow-right fs-2 text-primary mt-3"></i>
              </div>

              <div class="col-md-5">
                <label for="destination" class="form-label fw-bold">
                  <i class="bi bi-box-arrow-in-right me-1"></i> Destination Locale
                </label>
                <select name="destination" id="destination" class="form-select form-select-lg">
                  <option value="">-- Select destination --</option>
                  <% @locales.each do |locale| %>
                    <option value="<%= locale %>"><%= locale.upcase %></option>
                  <% end %>
                </select>
                <small class="form-text text-muted">The locale to check for missing keys.</small>
              </div>
            </div>

            <div class="d-grid">
              <%= submit_tag "Compare", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm border-info">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0"><i class="bi bi-info-circle"></i> How Sync Works</h6>
      </div>
      <div class="card-body">
        <p class="card-text small">
          <strong>1. Compare</strong><br>
          Deeply scans the source locale's key hierarchy and compares it against the destination.
        </p>
        <hr>
        <p class="card-text small">
          <strong>2. Review</strong><br>
          Shows all keys present in the source but missing in the destination.
        </p>
        <hr>
        <p class="card-text small mb-0">
          <strong>3. Sync</strong><br>
          Copies missing keys with their source values into the destination, preserving the full hierarchy.
        </p>
      </div>
    </div>
  </div>
</div>
